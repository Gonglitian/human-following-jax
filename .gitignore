# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Training artifacts (params from JAX runs are large; managed via Google Drive)
*.pkl
*.ckpt
training/runs/
wandb/

# IDE / venv
.venv/
.vscode/
.idea/

# Build (top-level Python wheel build, NOT colcon)
build/
dist/

# ── deployment/ ──────────────────────────────────────────────────────────────
# Colcon artifacts (regenerated by `colcon build`)
deployment/build/
deployment/install/
deployment/log/

# Third-party packages cloned by scripts/install_third_party.sh
deployment/src/third_party/

# PyTorch model weights (pulled from Google Drive by scripts/pull_models.sh)
deployment/src/core/decider/model_weight/
*.pt
*.pth

# Runtime logs from the robot (per-run CSV/JSON dumps)
deployment/src/core/decider/decider_logs/
deployment/**/ros2_frequency_log_*/
decider_logs/
ros2_frequency_log_*/
