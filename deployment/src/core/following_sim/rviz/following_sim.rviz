Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Perception1
        - /Planning1
        - /Decider1
      Splitter Ratio: 0.55
    Tree Height: 720
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Name: Tool Properties
    Splitter Ratio: 0.6
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    # ========================================================
    #                       Environment
    # ========================================================
    - Alpha: 0.4
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 130; 130; 130
      Enabled: true
      Line Style: {Line Width: 0.03, Value: Lines}
      Name: Grid (1 m)
      Normal Cell Count: 0
      Offset: {X: 0, Y: 0, Z: 0}
      Plane: XY
      Plane Cell Count: 30
      Reference Frame: <Fixed Frame>
      Value: true

    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: false
        base_footprint: {Value: true}
        base_link: {Value: false}
        laser_frame: {Value: true}
        map: {Value: true}
        odom: {Value: true}
      Marker Scale: 0.6
      Name: TF (filtered)
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        map:
          odom:
            base_footprint:
              base_link:
                back_left_wheel: {}
                back_right_wheel: {}
                front_left_wheel: {}
                front_right_wheel: {}
                imu_link: {}
                laser_frame: {}
      Update Interval: 0
      Value: true

    # ========================================================
    #                          Robot
    # ========================================================
    - Alpha: 1
      Class: rviz_default_plugins/RobotModel
      Collision Enabled: false
      Description File: ""
      Description Source: Topic
      Description Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /robot_description
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
        Link Tree Style: Links in Alphabetic Order
      Name: RobotModel
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true

    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Covariance:
        Orientation: {Alpha: 0.5, Color: 255; 255; 127, Color Style: Unique, Frame: Local, Offset: 1, Scale: 1, Value: false}
        Position: {Alpha: 0.3, Color: 204; 51; 204, Scale: 1, Value: false}
        Value: false
      Enabled: true
      Keep: 40
      Name: Odometry trail
      Position Tolerance: 0.1
      Shape:
        Alpha: 0.8
        Axes Length: 0.3
        Axes Radius: 0.02
        Color: 255; 140; 0
        Head Length: 0.1
        Head Radius: 0.04
        Shaft Length: 0.15
        Shaft Radius: 0.02
        Value: Arrow
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /odom
      Value: true

    # ========================================================
    #                       Perception
    # ========================================================
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds: {Max Value: 10, Min Value: -10, Value: true}
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/LaserScan
      Color: 255; 255; 255
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: Perception / LaserScan
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.02
      Style: Points
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        # Gazebo LaserScan plugin publishes BEST_EFFORT — RELIABLE readers won't get data
        Reliability Policy: Best Effort
        Value: /scan
      Use Fixed Frame: true
      Use rainbow: true
      Value: true

    # DR-SPAAM publishes a MarkerArray stream (DELETEALL + new-markers back-to-back)
    # that the RViz MarkerArray display sometimes renders as empty because the
    # DELETEALL arrives after the ADD. PoseArray on /dr_spaam_detections is one
    # message per frame — more reliable for eyeballing detections.
    - Alpha: 1
      Arrow Length: 0.15
      Axes Length: 0.3
      Axes Radius: 0.01
      Class: rviz_default_plugins/PoseArray
      Color: 255; 60; 60
      Enabled: true
      Head Length: 0.07
      Head Radius: 0.03
      Name: Perception / DR-SPAAM detections (PoseArray)
      Shaft Length: 0.23
      Shaft Radius: 0.01
      Shape: Axes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /dr_spaam_detections
      Value: true

    - Class: rviz_default_plugins/MarkerArray
      Enabled: false
      Name: Perception / DR-SPAAM markers (raw, may flicker)
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /dr_spaam_rviz
      Value: false

    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Perception / SORT tracked objects
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /tracked_objects_viz
      Value: true

    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Perception / CV predicted trajectories
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /predicted_trajectories_viz
      Value: true

    # Ground truth pedestrians from HuNavSim (target = bright green, bystanders = amber).
    # Compare with Perception/DR-SPAAM + SORT to see what the decider actually picks up.
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Ground truth / HuNav agents
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /human_states_viz
      Value: true

    # ========================================================
    #                       Planning
    # ========================================================
    - Alpha: 0.55
      Class: rviz_default_plugins/Map
      Color Scheme: map
      Draw Behind: true
      Enabled: true
      Name: Planning / OGM (10x10 m, 0.2 m/cell)
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /occupancy_grid
      Update Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /occupancy_grid_updates
      Use Timestamp: false
      Value: true

    # ========================================================
    #                       Decider
    # ========================================================
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Decider / action arrow
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /decider_action_marker
      Value: true

    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Decider / target goal
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /decider_goal_marker
      Value: true

    - Class: rviz_default_plugins/Marker
      Enabled: false
      Name: Decider / robot self-marker
      Namespaces: {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /decider_robot_marker
      Value: true

    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Injected obstacles
      Namespaces:
        walls: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /injected_obstacles
      Value: true

  Enabled: true
  Global Options:
    Background Color: 36; 36; 40
    Fixed Frame: odom
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /clicked_point
  Transformation:
    Current: {Class: rviz_default_plugins/TF}
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/ThirdPersonFollower
      Distance: 14.0
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point: {X: 0, Y: 0, Z: 0}
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Invert Z Axis: false
      Name: Follow robot (top-down)
      Near Clip Distance: 0.01
      # near-straight-down look
      Pitch: 1.45
      Target Frame: base_footprint
      Value: ThirdPersonFollower (rviz)
      Yaw: 0.0
    Saved:
      - Class: rviz_default_plugins/Orbit
        Distance: 20
        Focal Point: {X: 0, Y: 0, Z: 0}
        Name: Orbit (world)
        Pitch: 0.785
        Target Frame: <Fixed Frame>
        Yaw: 0.785
        Value: Orbit (rviz)
Window Geometry:
  Displays: {collapsed: false}
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Selection: {collapsed: false}
  Tool Properties: {collapsed: false}
  Views: {collapsed: false}
  Width: 1520
  X: 60
  Y: 60
